rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
        request.auth.token.email == 'illexthemaniac@gmail.com';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // Spots: Jeder eingeloggte User darf lesen/erstellen/updaten, nur Owner+Admin dürfen löschen
    match /spots/{spotId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isLoggedIn() && 
        (resource.data.createdBy == request.auth.uid || isAdmin());

      // Kommentare: Jeder eingeloggte User darf lesen/erstellen, eigene löschen + Admin
      match /comments/{commentId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn();
        allow delete: if isLoggedIn() && 
          (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }

    // Nur Admin darf allowed_emails schreiben, alle eingeloggten User dürfen lesen
    match /allowed_emails/{email} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}
